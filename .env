DATABASE_URL="file:./dev.db"

# ── Cron / Notifications ────────────────────────────────────
# CRON_SECRET=<shared-secret>          # Bearer token required by /api/cron/check
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...    # Slack alerts on score changes
# RESEND_API_KEY=re_...                # Resend email alerts (requires NOTIFICATION_EMAIL)
# NOTIFICATION_EMAIL=alerts@example.com
# APP_URL=http://localhost:3000         # Used for notification links
